# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Google Drive OAuth (daglierdal@gmail.com — Faz 1'de Workspace'e geçilecek)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/drive/callback
# Optional — defaults to GOOGLE_CLIENT_SECRET if not set
GOOGLE_TOKEN_ENCRYPTION_KEY=

# Supabase Storage bucket for documents
SUPABASE_DOCUMENTS_BUCKET=documents

# AI — @ai-sdk/anthropic reads ANTHROPIC_API_KEY automatically
ANTHROPIC_API_KEY=
